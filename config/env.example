# Chuka University GraphRAG - Environment Template
# Rename this to .env in the root directory

# 1. Neo4j Credentials
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password_here

# 2. Google Gemini API Keys (Supports Rotation)
GEMINI_API_KEY=your_key_1
GEMINI_API_KEY2=your_key_2
GEMINI_API_KEY3=your_key_3

# 3. Database (PostgreSQL required)
DATABASE_URL=postgresql://user:password@localhost:5432/chuka_db

# 4. App Settings
DEBUG=True
PORT=8501
