# Chuka University GraphRAG - Environment Template
# Copy this file to .env and fill in your actual credentials

# --- AI Model (Google Gemini) ---
# For production, we recommend a Tier 1+ API key to avoid quota limits.
# You can provide multiple comma-separated keys for automatic rotation:
# GEMINI_API_KEY=key1,key2,key3
GEMINI_API_KEY=your_gemini_api_key_here

# --- Knowledge Graph (Neo4j) ---
# Use an AuraDB instance for cloud production.
NEO4J_URI=bolt://your_neo4j_instance:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_secure_password_here

# --- Chat History (PostgreSQL) ---
# Required for multi-session chat persistence.
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5442/chuka_chat_history

# --- Logging (Optional) ---
LOG_LEVEL=INFO
